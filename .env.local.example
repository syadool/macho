NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Dashboard > Authentication > Providers > Google で設定してください。
# Google側のAuthorized redirect URI:
# https://your-project.supabase.co/auth/v1/callback

# Server-only keys
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-mini

# AI suggestion guardrails
AI_RATE_LIMIT_PER_DAY=10
AI_RATE_LIMIT_PER_MONTH=100
MONTHLY_AI_CALL_LIMIT=3000
AI_CACHE_TTL_HOURS=1
AI_MAX_TOKENS=3000

# Stripe Billing
STRIPE_RESTRICTED_KEY=rk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_GO=price_xxx
STRIPE_PRICE_PLUS=price_xxx
STRIPE_PRICE_PRO=price_xxx
