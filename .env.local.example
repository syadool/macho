NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Dashboard > Authentication > Providers > Google で設定してください。
# Google側のAuthorized redirect URI:
# https://your-project.supabase.co/auth/v1/callback

# Server-only keys
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-mini

# AI suggestion guardrails
AI_RATE_LIMIT_PER_DAY=10
AI_RATE_LIMIT_PER_MONTH=100
MONTHLY_AI_CALL_LIMIT=3000
AI_CACHE_TTL_HOURS=1
AI_MAX_TOKENS=1000
